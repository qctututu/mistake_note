{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "错题本 - 后端",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_DEBUG": "0",
        "PYTHONIOENCODING": "utf-8"
      },
      "args": [
        "run",
        "--host=0.0.0.0",
        "--port=5000"
      ],
      "jinja": false,
      "cwd": "${workspaceFolder}\\backend"
    }
  ]
}
